{
  "name": "shipcue",
  "version": 1,
  "commands": [
    { "name": "init", "writes": ["shipcue.config.json"], "network": false },
    { "name": "scan", "fixtureFlag": "--fixture", "writes": ["data/latest/shipcue-scan.json", "data/latest/repos.json"], "network": false },
    { "name": "build", "writes": ["dist-site/index.html", "dist-site/shipcue.json"], "network": false },
    { "name": "brief", "writes": ["briefs/*.md"], "network": false },
    { "name": "agent-prompt", "writes": [], "network": false }
  ],
  "safety": {
    "publishesReleases": false,
    "createsTags": false,
    "writesGithub": false,
    "requiresHumanReleaseAuthority": true
  },
  "verification": ["npm test", "npm run check", "npm run build", "npm run smoke", "bash scripts/validate.sh"]
}

{
  "name": "shipcue",
  "version": "0.1.0",
  "description": "Local-first release readiness radar for maintainers with too many repos.",
  "type": "module",
  "bin": {
    "shipcue": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "fixtures",
    "scripts",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "smoke": "npm run build && bash tests/cli-smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "github",
    "release",
    "maintenance",
    "dashboard",
    "cli",
    "agent"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/shipcue.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/shipcue/issues"
  },
  "homepage": "https://github.com/rogerchappel/shipcue#readme"
}
